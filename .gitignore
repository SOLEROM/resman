# ── Reference repos (dev only, cloned for design reference) ──────────────────
.ref/

# ── Runtime state (generated by the app, not source) ─────────────────────────
# Task queue, task logs, budget ledger, window schedule — produced at runtime,
# never source.
**/config/tasks.jsonl
**/config/budget.json
**/config/window_schedule.json
**/config/task-logs/
**/task-logs/

# User-specific config (vault paths, ttyd ports, etc.) — *.example is the template.
**/config/resman.yaml
**/config/schedule.yaml
# Legacy name — kept ignored so old checkouts don't accidentally commit it.
**/config/system.yaml

# Catch any stray *.log file that ends up in a config/ dir
**/config/**/*.log

# ── Server runtime logs ───────────────────────────────────────────────────────
**/control-plane/runtime/

# ── Vault / project data (not source) ────────────────────────────────────────
# Vaults are user data — never commit vault contents or test vaults.
testVault/
vaults/
**/.obsidian/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
.venv/
.venv-*/
env/
*.egg-info/
dist/
build/
*.egg
pip-log.txt

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Editor ────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Misspelled venvs (historical) ─────────────────────────────────────────────
.vevn*/
.vevn

