[Unit]
Description=Resman resource manager (port 5090)
After=network.target

[Service]
Type=simple
WorkingDirectory=__PROJECT_PATH__
ExecStart=__PROJECT_PATH__/run.sh --vname __VENV_NAME__ --public
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
